<mujoco model="so_arm100_task">
  <include file="so_arm100.xml"/>

  <statistic center="0.0 -0.25 0.08" extent="0.6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 -0.3 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Pick-and-place table + props sit in the SO-ARM100 reachable zone (y ~ -0.32, z in
         [0.04, 0.18]); the arm extends along -y with EEF home ~ (0, -0.41, 0.12). -->
    <!-- Collision bitmasks isolate the cube to the table only: the cube lives on bit 1, the
         table bridges bits 0+1, the arm stays on bit 0. So the cube rests on the table but the
         rigid jaw never knocks it during approach — the weld does the grasping. -->
    <geom name="table" type="box" pos="0.0 -0.32 0.04" size="0.16 0.12 0.02" rgba="0.8 0.8 0.8 1"
      contype="1" conaffinity="3"/>

    <body name="cube" pos="-0.06 -0.32 0.075">
      <freejoint name="cube_free"/>
      <geom name="cube_geom" type="box" size="0.015 0.015 0.015" rgba="0.9 0.3 0.2 1" mass="0.02"
        contype="2" conaffinity="2"/>
    </body>

    <site name="target" pos="0.06 -0.32 0.062" size="0.02" rgba="0.2 0.8 0.2 0.5"/>
  </worldbody>

  <equality>
    <weld name="grasp" body1="Moving_Jaw" body2="cube" active="false"/>
  </equality>
</mujoco>
